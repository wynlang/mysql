fn main() -> int {
    Test.init("MySQL Package")

    // Connection string building
    var host = "localhost"
    var user = "root"
    var db = "mydb"
    Test.assert_eq_str(host, "localhost", "host")
    Test.assert_eq_str(user, "root", "user")

    // Parameter substitution
    var sql = "INSERT INTO users (name, age) VALUES (?, ?)"
    var q = sql.replace_all("?", "'test'")
    Test.assert(q.contains("'test'"), "param sub")

    Test.summary()
    return 0
}
