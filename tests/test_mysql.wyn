test "host" {
    // Connection string building
    var host = "localhost"
    var user = "root"
    var db = "mydb"
    assert_eq(host, "localhost")
}

test "user" {
    // Connection string building
    var host = "localhost"
    var user = "root"
    var db = "mydb"
    assert_eq(user, "root")
}

test "param sub" {
    // Connection string building
    var host = "localhost"
    var user = "root"
    var db = "mydb"
    // Parameter substitution
    var sql = "INSERT INTO users (name, age) VALUES (?, ?)"
    var q = sql.replace_all("?", "'test'")
    assert(q.contains("'test'"))
}
